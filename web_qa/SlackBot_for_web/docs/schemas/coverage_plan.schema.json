{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/coverage_plan.schema.json",
  "title": "coverage_plan",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "stage",
    "created_at",
    "canonical_host",
    "coverage_targets",
    "exclusions",
    "budget_policy"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "stage": { "const": "coverage_plan" },
    "created_at": { "type": "string", "format": "date-time" },
    "canonical_host": { "type": "string", "minLength": 1 },
    "coverage_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_id", "reason", "priority"],
        "properties": {
          "target_id": { "type": "string" },
          "url_pattern": { "type": ["string", "null"] },
          "reason": { "type": "string" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] }
        },
        "additionalProperties": true
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "reason"],
        "properties": {
          "item": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "budget_policy": {
      "type": "object",
      "required": ["coverage_limit", "action_limit", "url_limit", "hard_timeout_minutes"],
      "properties": {
        "coverage_limit": { "const": "unlimited" },
        "action_limit": { "const": "unlimited" },
        "url_limit": { "const": "unlimited" },
        "hard_timeout_minutes": { "type": "integer", "const": 60 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
