{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/qa_report.schema.json",
  "title": "qa_report",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "stage",
    "created_at",
    "overall_status",
    "overall_reason",
    "summary",
    "summary_lines",
    "coverage_summary",
    "findings",
    "deep_dive_candidates",
    "unresolved_items"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "stage": { "const": "qa_report" },
    "created_at": { "type": "string", "format": "date-time" },
    "overall_status": { "type": "string", "enum": ["pass", "fail", "needs_review"] },
    "overall_reason": { "type": "string" },
    "summary": { "type": "string" },
    "summary_lines": { "type": "array", "items": { "type": "string" }, "minItems": 3, "maxItems": 3 },
    "coverage_summary": {
      "type": "object",
      "required": ["canonical_host", "visited_count", "visited_urls", "external_navigation_events"],
      "properties": {
        "canonical_host": { "type": "string" },
        "visited_count": { "type": "integer", "minimum": 0 },
        "visited_urls": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "external_navigation_events": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "reason": { "type": "string" },
              "returned": { "type": ["boolean", "null"] }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "type", "observation", "why_it_matters", "next_check", "evidence_refs"],
        "properties": {
          "id": { "type": "string" },
          "page_url": { "type": ["string", "null"] },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "type": { "type": "string" },
          "observation": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "next_check": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "deep_dive_candidates": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
    "unresolved_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason"],
        "properties": {
          "reason": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
