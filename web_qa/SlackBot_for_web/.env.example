SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Default agent. One of: gemini, openai, claude
DEFAULT_AGENT=gemini

# Gemini API settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_FALLBACK_MODELS=gemini-3-flash-preview,gemini-flash-lite-latest,gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=300
# Gemini AFC hard cap (MVP 권장: 크게 설정하고 일단 무제한에 가깝게 운용)
GEMINI_MAX_REMOTE_CALLS=5000

# OpenAI API settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=300

# Orchestration policy
USE_LANGGRAPH=true
HARD_TIMEOUT_MINUTES=60
# Self-healing policy is fixed in code:
# (Vibium 5 -> DevTools 3) -> (Vibium 5 -> DevTools 2) -> (Vibium 5) -> HITL

# Vibium MCP server command
VIBIUM_MCP_COMMAND=npx
VIBIUM_MCP_ARGS=vibium mcp --headless

# Optional Chrome DevTools MCP server command
DEVTOOLS_MCP_COMMAND=
DEVTOOLS_MCP_ARGS=

# Artifact output root
ARTIFACT_ROOT=artifacts

# Custom mode storage (legacy PROMPT_PRESET_STORE is still accepted)
PROMPT_MODE_STORE=artifacts/_runtime/custom_presets.json

# Slack output mode: false=business summary, true=include debug info (token/steps)
SLACK_VERBOSE_OUTPUT=false

# Local vector memory retrieval
MEMORY_EMBEDDING_BACKEND=sentence_transformers
MEMORY_EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct
MEMORY_COMPARE_MODELS=intfloat/multilingual-e5-large-instruct
