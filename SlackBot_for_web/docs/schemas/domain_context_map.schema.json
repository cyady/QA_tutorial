{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/domain_context_map.schema.json",
  "title": "domain_context_map",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "stage",
    "created_at",
    "target_url",
    "canonical_host",
    "pages",
    "external_links",
    "screenshots"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "stage": { "const": "domain_context_map" },
    "created_at": { "type": "string", "format": "date-time" },
    "target_url": { "type": "string", "format": "uri" },
    "canonical_host": { "type": "string", "minLength": 1 },
    "note": { "type": ["string", "null"] },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "depth"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "depth": { "type": "integer", "minimum": 0 },
          "title": { "type": ["string", "null"] },
          "landmarks": { "type": "array", "items": { "type": "string" } },
          "header_links": { "type": "array", "items": { "type": "string", "format": "uri" } },
          "footer_links": { "type": "array", "items": { "type": "string", "format": "uri" } },
          "ctas": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label"],
              "properties": {
                "label": { "type": "string" },
                "target_url": { "type": ["string", "null"] }
              },
              "additionalProperties": true
            }
          },
          "forms": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "form_id": { "type": ["string", "null"] },
                "fields": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "external_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "source_page": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string" },
          "page_url": { "type": ["string", "null"] },
          "note": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
